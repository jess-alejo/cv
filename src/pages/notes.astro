---
import { getCollection, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const entries = (await getCollection('notes'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const categories = [...new Set(entries.flatMap(e => e.data.category))].sort();

const notesData = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---
<PageLayout title="Notes - JEA">
  {entries.length === 0 ? (
    <p class="text-center" style="color: var(--bs-secondary-color, #a5b3ce)">No notes yet.</p>
  ) : (
    <>
      <div class="notes-controls mb-4 d-flex flex-wrap gap-2 align-items-center">
        <div class="notes-search-wrapper flex-grow-1">
          <div class="input-group">
            <span class="input-group-text notes-search-icon">
              <i class="bi bi-search"></i>
            </span>
            <input
              id="notes-search"
              type="text"
              class="form-control notes-search-input"
              placeholder="Search notes..."
              autocomplete="off"
            />
          </div>
        </div>
        <div class="notes-category-filter d-flex flex-wrap gap-2">
          <button class="btn notes-filter-btn active" data-category="">All</button>
          {categories.map(cat => (
            <button class="btn notes-filter-btn" data-category={cat}>{cat}</button>
          ))}
        </div>
      </div>

      <div id="notes-count" class="small mb-3" style="color: #a5b3ce">
        {entries.length} note{entries.length !== 1 ? 's' : ''}
      </div>

      <div id="notes-list" class="row g-4">
        {notesData.map(({ entry, Content }) => (
          <div
            class="col-12 col-md-6 note-entry"
            data-title={entry.data.title.toLowerCase()}
            data-category={JSON.stringify(entry.data.category)}
            data-body={entry.body?.toLowerCase() ?? ''}
          >
            <article class="note-card h-100">
              <div class="note-card-header d-flex flex-wrap gap-1">
                {entry.data.category.map(cat => (
                  <span class="badge notes-category-badge">{cat}</span>
                ))}
              </div>
              <h3 class="resume-position-title note-card-title">{entry.data.title}</h3>
              <div class="resume-summary-desc note-card-body">
                <Content />
              </div>
            </article>
          </div>
        ))}
      </div>

      <p id="notes-empty" class="text-center d-none" style="color: var(--bs-secondary-color, #a5b3ce)">
        No notes match your search.
      </p>
    </>
  )}
</PageLayout>

<style>
  .notes-search-icon {
    background: transparent;
    border-color: rgba(255,255,255,0.15);
    color: #a5b3ce;
  }

  .notes-search-input {
    background: transparent;
    border-color: rgba(255,255,255,0.15);
    color: inherit;
  }

  .notes-search-input:focus {
    background: transparent;
    border-color: rgba(255,255,255,0.35);
    color: inherit;
    box-shadow: none;
  }

  .notes-search-input::placeholder {
    color: #6c7a91;
  }

  .notes-filter-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: #a5b3ce;
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    transition: all 0.15s;
  }

  .notes-filter-btn:hover,
  .notes-filter-btn.active {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.35);
    color: #fff;
  }

  .notes-category-badge {
    background: rgba(255,255,255,0.1);
    color: #a5b3ce;
    font-weight: 500;
    font-size: 0.75rem;
  }

  .note-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.15s;
  }

  .note-card:hover {
    border-color: rgba(255,255,255,0.25);
  }

  .note-card-header {
    margin-bottom: 0.25rem;
  }

  .note-card-title {
    font-size: 1rem;
    margin-bottom: 0;
  }

  .note-card-body {
    flex: 1;
    font-size: 0.9rem;
  }
</style>

<script>
  const searchInput = document.getElementById('notes-search') as HTMLInputElement | null;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.notes-filter-btn');
  const noteEntries = document.querySelectorAll<HTMLElement>('.note-entry');
  const emptyMsg = document.getElementById('notes-empty');
  const countEl = document.getElementById('notes-count');

  let activeCategory = '';
  let searchQuery = '';

  function updateNotes() {
    let visible = 0;

    noteEntries.forEach(entry => {
      const title = entry.dataset.title ?? '';
      const body = entry.dataset.body ?? '';
      const categories: string[] = JSON.parse(entry.dataset.category ?? '[]');

      const matchesCategory = !activeCategory || categories.includes(activeCategory);
      const matchesSearch = !searchQuery ||
        title.includes(searchQuery) ||
        body.includes(searchQuery) ||
        categories.some(c => c.toLowerCase().includes(searchQuery));

      const show = matchesCategory && matchesSearch;
      entry.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) {
      countEl.textContent = `${visible} note${visible !== 1 ? 's' : ''}`;
    }
    if (emptyMsg) {
      emptyMsg.classList.toggle('d-none', visible > 0);
    }
  }

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    updateNotes();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.category ?? '';
      updateNotes();
    });
  });
</script>
